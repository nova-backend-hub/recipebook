# ==========================================
# RECIPEBOOK ENV TEMPLATE - LOCAL DEVELOPMENT
# ==========================================

# 1. API Server Settings
PORT=5000
NODE_ENV=development

# 2. Database Connection (PostgreSQL connection string)
# Replace with your PostgreSQL credentials (e.g. Supabase, local instance, or Cloud SQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/recipebook?schema=public"

# 3. JWT Core Security Keys
# Generate random long alphanumeric strings for production!
JWT_SECRET="recipebook-jwt-super-secret-key-12345"
JWT_REFRESH_SECRET="recipebook-jwt-refresh-super-secret-key-54321"

# 4. Google Gemini AI API Configurations
# Obtain an API key from Google AI Studio (https://aistudio.google.com/)
# If left empty, RecipeBook runs inside simulated parsing fallback engine
GEMINI_API_KEY=""

# 5. Default Administrator Profiles
ADMIN_USERNAME="Soli"
ADMIN_PASSWORD="Soliman@1234"

# 6. Redis Connection (Optional local caching fallbacks)
REDIS_URL="redis://localhost:6379"
